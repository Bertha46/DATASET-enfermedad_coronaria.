#########################################################
# 1. CARGA DE LIBRERÍAS
#########################################################

library(tidyverse)
library(caret)
library(pROC)
library(ggplot2)

#########################################################
# 2. CARGA DEL DATASET
#########################################################

datos <- read.csv("enfermedad_coronaria.csv")

cat("Primeras filas del dataset:\n")
head(datos)

#########################################################
# 3. EXPLORACIÓN DE LOS DATOS
#########################################################

cat("\nEstructura de datos:\n")
str(datos)

cat("\nResumen estadístico:\n")
summary(datos)

cat("\nDimensiones:\n")
dim(datos)

cat("\nTipos de datos:\n")
sapply(datos, class)

#########################################################
# 4. LIMPIEZA Y TRANSFORMACIÓN
#########################################################

cat("\nValores faltantes por columna:\n")
colSums(is.na(datos))

# Eliminar registros incompletos
datos <- na.omit(datos)

# Convertir variable objetivo a factor
datos$TenYearCHD <- as.factor(datos$TenYearCHD)

cat("\nVerificación de la variable objetivo:\n")
str(datos$TenYearCHD)

#########################################################
# 5. DIVISIÓN DE DATOS
#########################################################

set.seed(123)

indices <- createDataPartition(
  datos$TenYearCHD,
  p = 0.80,
  list = FALSE
)

train <- datos[indices, ]
test <- datos[-indices, ]

cat("\nDatos entrenamiento:\n")
dim(train)

cat("\nDatos prueba:\n")
dim(test)

#########################################################
# 6. MODELO DE REGRESIÓN LOGÍSTICA
#########################################################

modelo <- glm(
  TenYearCHD ~ .,
  data = train,
  family = binomial(link = "logit")
)

#########################################################
# 7. RESUMEN DEL MODELO
#########################################################

cat("\nResumen del modelo:\n")
summary(modelo)

#########################################################
# 8. VARIABLES SIGNIFICATIVAS
#########################################################

coeficientes <- summary(modelo)$coefficients

cat("\nCoeficientes:\n")
print(coeficientes)

variables_significativas <- coeficientes[
  coeficientes[,4] < 0.05,
]

cat("\nVariables significativas:\n")
print(variables_significativas)

#########################################################
# 9. GRÁFICO DE COEFICIENTES
#########################################################

coef_df <- data.frame(
  Variable = rownames(coeficientes),
  Coeficiente = coeficientes[,1]
)

coef_df <- coef_df[-1,]

grafico_coef <- ggplot(
  coef_df,
  aes(
    x = reorder(Variable, Coeficiente),
    y = Coeficiente
  )
) +
  geom_bar(stat = "identity") +
  coord_flip() +
  labs(
    title = "Importancia de Variables",
    x = "Variables",
    y = "Coeficiente"
  ) +
  theme_minimal()

print(grafico_coef)

ggsave(
  "coeficientes_modelo.png",
  grafico_coef,
  width = 8,
  height = 6
)

#########################################################
# 10. PREDICCIONES
#########################################################

probabilidades <- predict(
  modelo,
  newdata = test,
  type = "response"
)

predicciones <- ifelse(
  probabilidades > 0.5,
  1,
  0
)

predicciones <- as.factor(predicciones)

#########################################################
# 11. MATRIZ DE CONFUSIÓN
#########################################################

cm <- confusionMatrix(
  predicciones,
  test$TenYearCHD,
  positive = "1"
)

cat("\nMatriz de Confusión:\n")
print(cm)

#########################################################
# 12. MÉTRICAS DE EVALUACIÓN
#########################################################

accuracy <- cm$overall["Accuracy"]

precision <- cm$byClass["Pos Pred Value"]

recall <- cm$byClass["Sensitivity"]

specificity <- cm$byClass["Specificity"]

f1 <- 2 * (
  (precision * recall) /
  (precision + recall)
)

metricas <- data.frame(
  Accuracy = accuracy,
  Precision = precision,
  Recall = recall,
  Specificity = specificity,
  F1_Score = f1
)

cat("\nMétricas:\n")
print(metricas)

#########################################################
# 13. CURVA ROC
#########################################################

roc_obj <- roc(
  test$TenYearCHD,
  probabilidades
)

png(
  "curva_ROC.png",
  width = 1200,
  height = 800
)

plot(
  roc_obj,
  col = "blue",
  lwd = 3,
  main = "Curva ROC"
)

abline(
  a = 0,
  b = 1,
  lty = 2,
  col = "red"
)

dev.off()

auc_modelo <- auc(roc_obj)

cat("\nAUC:\n")
print(auc_modelo)

#########################################################
# 14. MODELO SIMPLIFICADO
#########################################################

modelo_reducido <- glm(
  TenYearCHD ~ age + sysBP,
  data = train,
  family = binomial()
)

cat("\nResumen Modelo Simplificado:\n")
summary(modelo_reducido)

#########################################################
# 15. COMPARACIÓN DE MODELOS
#########################################################

prob_reducido <- predict(
  modelo_reducido,
  newdata = test,
  type = "response"
)

roc_reducido <- roc(
  test$TenYearCHD,
  prob_reducido
)

auc_reducido <- auc(roc_reducido)

comparacion <- data.frame(
  Modelo = c(
    "Completo",
    "Simplificado"
  ),
  AUC = c(
    auc_modelo,
    auc_reducido
  )
)

print(comparacion)

#########################################################
# 16. EXPORTACIÓN DE RESULTADOS
#########################################################

write.csv(
  coef_df,
  "coeficientes_modelo.csv",
  row.names = FALSE
)

write.csv(
  metricas,
  "metricas_modelo.csv",
  row.names = FALSE
)

write.csv(
  comparacion,
  "comparacion_modelos.csv",
  row.names = FALSE
)

capture.output(
  cm,
  file = "matriz_confusion.txt"
)

cat("\nArchivos exportados correctamente.\n")

